# Shopify App
SHOPIFY_API_KEY=your-api-key
SHOPIFY_API_SECRET=your-api-secret
SHOPIFY_APP_URL=https://your-app.fly.dev
SCOPES=write_gift_cards,read_gift_cards,read_customers,write_customers,write_gift_card_transactions

# Database
DATABASE_URL=postgresql://datora:datora@localhost:5432/datora_bulk_store_credits?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Worker Service
# Local dev: http://localhost:8080
# Fly.io: http://worker.process.datora-bulk-store-credits.internal:8080
WORKER_SERVICE_URL=http://localhost:8080
PRESHARED_AUTH_HEADER_KEY=X-Custom-PSK
PRESHARED_AUTH_HEADER_VALUE=your-preshared-key

# Encryption
GIFT_CARD_ENCRYPTION_KEY=your-64-char-hex-key-for-aes-256-cbc

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email
SMTP_PASS=your-password
SMTP_FROM=your-email

# Optional
SHOP_CUSTOM_DOMAIN=

# Billing
# Set to "true" once the App Store listing is approved and real charges should be made.
# When unset/false, billing.check / billing.require run with isTest=true for every shop.
BILLING_LIVE=false
